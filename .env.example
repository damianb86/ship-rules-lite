# Ship Rules Lite
# Copy to .env for local development. Do not commit real secrets.
# Default local PostgreSQL bootstrap uses host 127.0.0.1, port 5432 and user qorve_dev.

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://example.com
SCOPES=read_products,read_delivery_customizations,write_delivery_customizations,read_validations,write_validations
DATABASE_URL=postgresql://qorve_dev:replace-with-local-password@127.0.0.1:5432/ship_rules_lite
SHOP_CUSTOM_DOMAIN=
NODE_ENV=development
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Docker/deployment placeholders
COMPOSE_PROJECT_NAME=ship-rules-lite
APP_DB_NAME=ship_rules_lite
APP_DB_USER=qorve_dev
APP_DB_PASSWORD=replace-with-local-password
APP_HOST=ship-rules-lite.example.com
CONTACT_EMAIL=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
NODE_OPTIONS=
