# Ship Rules Lite
# Copy to .env for local development. Do not commit real secrets.

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://example.com
SCOPES=read_products,read_delivery_customizations,write_delivery_customizations,read_validations,write_validations
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/ship_rules_lite
SHOP_CUSTOM_DOMAIN=
NODE_ENV=development

# Docker deployment placeholders
COMPOSE_PROJECT_NAME=ship-rules-lite
APP_DB_NAME=ship_rules_lite
APP_DB_USER=ship_rules_lite_user
APP_DB_PASSWORD=replace_me
APP_HOST=ship-rules-lite.example.com
CONTACT_EMAIL=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
NODE_OPTIONS=
